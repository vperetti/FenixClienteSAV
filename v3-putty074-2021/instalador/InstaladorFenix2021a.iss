; Script generated by the Inno Setup Script Wizard.
; SEE THE DOCUMENTATION FOR DETAILS ON CREATING INNO SETUP SCRIPT FILES!

[Setup]
AppName=Fenix
AppVerName=Fenix Cliente 2021a
AppPublisher=BasePro
AppPublisherURL=http://www.basepro.com.br
AppSupportURL=http://www.basepro.com.br
AppUpdatesURL=http://www.basepro.com.br
DefaultDirName=c:\Fenix
DefaultGroupName=Fenix
OutputDir=C:\Cliente
OutputBaseFilename=InstaladorFenix2021a
DirExistsWarning=no
DisableDirPage=yes
DisableProgramGroupPage=yes

[Components]
Name: "principal"; Description: "Cliente Fenix"; Types: full compact custom; Flags: fixed
Name: "suporte"; Description: "Suporte"; Types: full
Name: "fenixreport"; Description: "Fenix Report"; Types: full
Name: "ajuda"; Description: "Arquivos de Ajuda"; Types: full

[Files]
Source: "C:\Cliente\ClienteSAV.exe"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: principal
Source: "C:\Cliente\Update2021a\Atualiza2021a.reg"; DestDir: "{app}"; CopyMode: alwaysoverwrite
Source: "C:\Cliente\fenix.ico"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: principal
Source: "C:\Cliente\fenixReport.jar"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: fenixreport
Source: "C:\Cliente\lib\*"; DestDir: "{app}\lib\"; CopyMode: alwaysoverwrite; Components: fenixreport
Source: "C:\Cliente\suporte.exe"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: suporte
Source: "C:\Cliente\suportecliente.exe"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: suporte
Source: "C:\Cliente\ultravnc\*"; DestDir: "{app}\ultravnc\"; CopyMode: alwaysoverwrite; Components: suporte
Source: "C:\Cliente\fenix.ico"; DestDir: "{app}"; CopyMode: alwaysoverwrite; Components: suporte

[Icons]
Name: "{group}\Fenix"; Filename: "{app}\ClienteSAV.exe"; Parameters: " -load sav"; IconFilename: "{app}\fenix.ico"; Components: principal
Name: "{group}\Configuraçăo"; Filename: "{app}\ClienteSAV.exe"; IconFilename: "{app}\fenix.ico"; Components: principal
Name: "{commondesktop}\Fenix"; Filename: "{app}\ClienteSAV.exe"; Parameters: " -load sav"; IconFilename: "{app}\fenix.ico"; Components: principal
Name: "{commonappdata}\Microsoft\Internet Explorer\Quick Launch\Fenix"; Filename: "{app}\ClienteSAV.exe"; Parameters: " -load sav"; IconFilename: "{app}\fenix.ico"; Components: principal
Name: "{group}\Suporte\Conectar ao Suporte"; Filename: "{app}\suportecliente.exe"; WorkingDir: "{app}"; IconFilename: "{app}\fenix.ico"; Components: suporte
Name: "{group}\Suporte\Prestar Suporte"; Filename: "{app}\suporte.exe"; WorkingDir: "{app}"; IconFilename: "{app}\fenix.ico"; Components: suporte
Name: "{group}\Suporte\Registro de Solicitaçăo"; Filename: "http://suporte.basepro.com.br/"

[Run]
Filename: "regedit "; Parameters: "{app}\Atualiza2021a.reg"

